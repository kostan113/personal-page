---
---

<section class="hero section" id="hero" aria-label="Главная секция">
  <div class="container">
    <div class="hero-layout">

      <!-- LEFT: текст -->
      <div class="hero-content">

        <div class="hero-badge animate-fade-up" style="animation-delay:0.05s">
          <span class="status-dot" aria-hidden="true"></span>
          <span class="text-mono" style="font-size:var(--text-xs);color:var(--c-text-secondary)">Открыт к предложениям</span>
        </div>

        <h1 class="hero-name animate-fade-up" style="animation-delay:0.1s">
          Константин<br />Попов
        </h1>

        <p class="hero-title animate-fade-up" style="animation-delay:0.18s">
          Senior Project Manager
        </p>

        <p class="hero-tagline animate-fade-up" style="animation-delay:0.24s">
          Автоматизация&nbsp;•&nbsp;Внедрения&nbsp;•&nbsp;Интеграции&nbsp;•&nbsp;Производственные&nbsp;системы
        </p>

        <p class="hero-description animate-fade-up" style="animation-delay:0.32s">
          Управляю сложными проектами автоматизации и внедрения на производственных предприятиях.
          6+ лет опыта, проекты до 30+ млн ₽, реализация в РФ, РБ и ОАЭ.
        </p>

        <div class="hero-actions animate-fade-up" style="animation-delay:0.4s">
          <a href="https://t.me/Kost_Pop" target="_blank" rel="noopener noreferrer" class="btn btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Написать в Telegram
          </a>
          <a href="#contact" class="btn btn--outline">
            Связаться
          </a>
        </div>

        <div class="hero-geo animate-fade-up" style="animation-delay:0.46s">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 14 8 14s8-8.75 8-14a8 8 0 0 0-8-8z"/></svg>
          <span>РФ / РБ / ОАЭ</span>
        </div>

      </div>

      <!-- RIGHT: фото -->
      <div class="hero-photo-wrap animate-fade-in" style="animation-delay:0.15s" aria-hidden="true">
        <img
          src="/photo.jpg"
          alt="Константин Попов — Senior Project Manager"
          class="hero-photo"
          width="520"
          height="600"
          loading="eager"
          decoding="async"
        />
        <div class="photo-overlay"></div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(2rem, 6vh, 5rem);
    padding-bottom: 0;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    min-height: clamp(460px, 70vh, 700px);
  }

  /* ── Left ── */
  .hero-content {
    max-width: 580px;
    padding-bottom: clamp(2rem, 5vh, 4rem);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--c-bg-card);
    border: 1px solid var(--c-border);
    border-radius: 100px;
    padding: 0.35rem 0.85rem;
    margin-bottom: 1.75rem;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    background: var(--c-success);
    border-radius: 50%;
    animation: pulse-dot 2.5s ease-in-out infinite;
  }

  .hero-name {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--c-text-primary);
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: clamp(var(--text-sm), 2vw, var(--text-base));
    font-weight: 500;
    color: var(--c-accent);
    letter-spacing: 0.05em;
    margin-bottom: 0.6rem;
  }

  .hero-tagline {
    font-size: clamp(var(--text-sm), 2.2vw, var(--text-lg));
    color: var(--c-text-secondary);
    font-weight: 400;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .hero-description {
    font-size: var(--text-base);
    color: var(--c-text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .hero-geo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    color: var(--c-text-muted);
    font-family: var(--font-mono);
  }

  /* ── Right: photo ── */
  .hero-photo-wrap {
    position: relative;
    width: clamp(240px, 32vw, 420px);
    align-self: stretch;
    overflow: hidden;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    flex-shrink: 0;
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: grayscale(15%);
  }

  /* fade to bg at bottom */
  .photo-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 35%;
    background: linear-gradient(to top, var(--c-bg) 0%, transparent 100%);
    pointer-events: none;
  }

  /* ── Mobile ── */
  @media (max-width: 720px) {
    .hero-layout {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-photo-wrap {
      width: 100%;
      max-height: 340px;
      border-radius: var(--radius-lg);
      order: -1;
    }

    .hero-photo {
      object-position: center 20%;
    }

    .hero-content {
      padding-bottom: 2rem;
    }
  }
</style>
