---
import { metrics } from '../data/metrics';
---

<section class="section" id="metrics" aria-labelledby="metrics-heading">
  <div class="container">
    <p class="section-label" id="metrics-heading">Ключевые показатели</p>

    <div class="metrics-grid" role="list">
      {metrics.map((m) => (
        <div class="metric-item card" role="listitem">
          <div class="metric-value">{m.value}</div>
          <div class="metric-label">{m.label}</div>
          <div class="metric-desc">{m.description}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 1px;
    background: var(--c-border);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .metric-item {
    background: var(--c-bg-card);
    border-radius: 0;
    border: none;
    padding: 1.75rem 1.5rem;
    transition: background var(--dur-normal) var(--ease-out);
  }

  .metric-item:hover {
    background: var(--c-bg-subtle);
    box-shadow: none;
  }

  .metric-value {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--c-accent-light);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.35rem;
    font-family: var(--font-mono);
  }

  .metric-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--c-text-primary);
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }

  .metric-desc {
    font-size: var(--text-xs);
    color: var(--c-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
