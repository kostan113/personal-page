---
---

<section class="section" id="contact" aria-labelledby="contact-heading">
  <div class="container">
    <p class="section-label">Контакты</p>
    <h2 class="section-title" id="contact-heading">Связаться</h2>
    <p class="section-subtitle">
      Открыт к обсуждению новых проектов и предложений о сотрудничестве.
    </p>

    <div class="contact-grid">

      <a
        href="https://t.me/Kost_Pop"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card card"
        aria-label="Написать в Telegram: @Kost_Pop"
      >
        <div class="contact-icon contact-icon--tg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </div>
        <div class="contact-details">
          <div class="contact-type">Telegram</div>
          <div class="contact-value">@Kost_Pop</div>
        </div>
        <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>

      <a
        href="mailto:kocty13@yandex.ru"
        class="contact-card card"
        aria-label="Написать на email: kocty13@yandex.ru"
      >
        <div class="contact-icon contact-icon--mail">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div class="contact-details">
          <div class="contact-type">Email</div>
          <div class="contact-value">kocty13@yandex.ru</div>
        </div>
        <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>

      <a
        href="tel:+79853094805"
        class="contact-card card"
        aria-label="Позвонить: +7 (985) 309-48-05"
      >
        <div class="contact-icon contact-icon--phone">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="contact-details">
          <div class="contact-type">Телефон</div>
          <div class="contact-value">+7 (985) 309-48-05</div>
        </div>
        <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>

    </div>

    <p class="contact-note">
      Предпочтительный способ связи — Telegram. Работаю удалённо, доступен для встреч в Москве.
    </p>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    transition: border-color var(--dur-normal) var(--ease-out),
                box-shadow var(--dur-normal) var(--ease-out),
                transform var(--dur-normal) var(--ease-out);
  }

  .contact-card:hover {
    transform: translateY(-2px);
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    border: 1px solid var(--c-border);
    flex-shrink: 0;
    transition: background var(--dur-fast), border-color var(--dur-fast);
  }

  .contact-card:hover .contact-icon {
    background: var(--c-accent-dim);
    border-color: rgba(59,130,246,0.3);
  }

  .contact-icon--tg  { color: #2AABEE; }
  .contact-icon--mail { color: var(--c-accent-light); }
  .contact-icon--phone { color: var(--c-success); }

  .contact-details {
    flex: 1;
  }

  .contact-type {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--c-text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.15rem;
  }

  .contact-value {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--c-text-primary);
  }

  .contact-arrow {
    color: var(--c-text-muted);
    opacity: 0;
    transition: opacity var(--dur-fast), color var(--dur-fast);
  }

  .contact-card:hover .contact-arrow {
    opacity: 1;
    color: var(--c-accent-light);
  }

  .contact-note {
    font-size: var(--text-sm);
    color: var(--c-text-muted);
    text-align: center;
    font-family: var(--font-mono);
  }
</style>
